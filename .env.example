# EmailJS client configuration
# These VITE_* values are exposed to the browser build. They are not secret server-side credentials.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_COMMITTEE_TEMPLATE_ID=your_committee_template_id
VITE_EMAILJS_COMMITTEE_MEMBER_TEMPLATE_ID=your_committee_member_template_id
VITE_EMAILJS_PROFESSOR_TEMPLATE_ID=your_professor_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key
VITE_PUBLIC_SITE_URL=https://your-public-domain.example

# Optional local-only check-in credentials for localhost testing.
# Do not rely on these in production because VITE_* values are exposed to the browser.
VITE_CHECKIN_ADMIN_USERNAME=admin
VITE_LOCAL_CHECKIN_ADMIN_PASSWORD=change_me_for_local_admin
# Legacy alias still supported by the app:
# VITE_ADMIN_PASSWORD=change_me_for_local_admin
VITE_CHECKIN_COMMITTEE_EMAIL=comite@example.com
VITE_CHECKIN_COMMITTEE_PASSWORD=change_me_for_local_dev

# Optional local-only overrides for hidden admin access and local deletion checks.
VITE_LOCAL_ADMIN_ACCESS_HASH=replace_with_sha256_hash
VITE_LOCAL_ADMIN_DELETE_PASSWORD_HASH=replace_with_sha256_hash
